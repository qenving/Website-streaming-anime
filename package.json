{
  "name": "website-streaming-anime",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "postbuild": "node scripts/postbuild.js",
    "preview": "vite preview",
    "server": "node server/index.js",
    "server:dev": "cross-env NODE_ENV=development nodemon --watch server --ext js,json --exec node server/index.js",
    "dev:full": "cross-env NODE_ENV=development concurrently \"npm run server:dev\" \"npm run dev\"",
    "test": "vitest run --workspace vitest.workspace.js --passWithNoTests",
    "test:watch": "vitest --workspace vitest.workspace.js --passWithNoTests",
    "test:unit": "vitest run --workspace vitest.workspace.js --passWithNoTests",
    "db:seed": "node server/scripts/seed.js",
    "db:reset": "node server/scripts/reset.js",
    "test:backend": "vitest run --workspace vitest.workspace.js --project backend --passWithNoTests",
    "test:frontend": "vitest run --workspace vitest.workspace.js --project frontend --passWithNoTests"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.2",
    "framer-motion": "^12.23.22",
    "lucide-react": "^0.544.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.9.3",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "anidbjs": "^2.4.4",
    "better-sqlite3": "^11.7.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.7",
    "node-cache": "^5.1.2",
    "pino": "^9.4.0",
    "sanitize-html": "^2.14.0",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "postcss": "^8.5.6",
    "svgo": "^4.0.0",
    "tailwindcss": "^3.4.13",
    "vite": "^7.1.7",
    "vite-plugin-image-optimizer": "^2.0.2",
    "vite-plugin-pwa": "^1.0.3",
    "vite-plugin-sitemap": "^0.8.2",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.7",
    "supertest": "^7.1.1",
    "vitest": "^2.1.5",
    "pino-pretty": "^11.2.2",
    "@testing-library/react": "^16.0.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/user-event": "^14.5.2",
    "@vitest/coverage-v8": "^2.1.5"
  }
}
